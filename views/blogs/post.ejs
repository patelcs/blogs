<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <title><%= blog.title %></title>
</head>

<body>
    <%- include("../components/Navbar") %>

    <main class="page">
        <header class="hero">
            <p class="eyebrow"><%= blog.eyebrow %></p>
            <h1><%= blog.title %></h1>
            <p class="subtitle"><%= blog.subtitle %></p>
            <div class="meta">
                <% if (blog.date) { %>
                    <span><%= blog.date %></span>
                <% } %>
                <% blog.meta.forEach((item) => { %>
                    <span><%= item %></span>
                <% }) %>
            </div>
        </header>

        <article class="post">
            <%
                const escapeHtml = (value) => String(value)
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#39;");

                const escapeAttr = (value) => String(value)
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#39;");

                const getPartClass = (part) => {
                    const classes = [];
                    if (part.bold) classes.push("line-bold");
                    if (part.tone) classes.push(`line-tone-${part.tone}`);
                    if (part.className) classes.push(part.className);
                    return classes.join(" ");
                };

                const renderParts = (parts) => parts.map((part) => {
                    if (part.type === "link") {
                        const linkText = escapeHtml(part.text || "");
                        const linkUrl = escapeAttr(part.url || "#");
                        const partClass = getPartClass(part);
                        const highlightClass = part.highlight ? "highlight highlight-strong" : "";
                        const linkInner = highlightClass
                            ? `<span class="${highlightClass}">${linkText}</span>`
                            : linkText;
                        const wrapped = partClass
                            ? `<span class="${partClass}">${linkInner}</span>`
                            : linkInner;
                        return `<a href="${linkUrl}" target="_blank" rel="noreferrer">${wrapped}</a>`;
                    }
                    if (part.type === "highlight") {
                        const partClass = getPartClass(part);
                        const inner = `<span class="highlight highlight-strong">${escapeHtml(part.text || "")}</span>`;
                        return partClass ? `<span class="${partClass}">${inner}</span>` : inner;
                    }
                    const partClass = getPartClass(part);
                    const text = escapeHtml(part.value || "");
                    return partClass ? `<span class="${partClass}">${text}</span>` : text;
                }).join("");

                const renderParagraph = (paragraph, highlights, highlightsStrong) => {
                    if (Array.isArray(paragraph)) {
                        return { html: renderParts(paragraph), className: "" };
                    }
                    if (paragraph && typeof paragraph === "object") {
                        if (Array.isArray(paragraph.parts)) {
                            const classes = [];
                            if (paragraph.bold) classes.push("line-bold");
                            if (paragraph.lineTone) classes.push(`line-tone-${paragraph.lineTone}`);
                            return { html: renderParts(paragraph.parts), className: classes.join(" ") };
                        }
                        const classes = [];
                        if (paragraph.bold) classes.push("line-bold");
                        if (paragraph.lineTone) classes.push(`line-tone-${paragraph.lineTone}`);
                        return { html: escapeHtml(paragraph.text || ""), className: classes.join(" ") };
                    }
                    return { html: escapeHtml(paragraph || ""), className: "" };
                };
            %>
            <% blog.sections.forEach((section, index) => { %>
                <% if (section.type === 'separator') { %>
                    <hr class="post-separator" />
                <% } else { %>
                <% const prevIsSeparator = index > 0 && blog.sections[index - 1].type === 'separator'; %>
                <section class="<%= [section.type === 'closing' ? 'closing' : '', prevIsSeparator ? 'no-divider' : ''].filter(Boolean).join(' ') %>">
                    <% if (section.title) { %>
                        <h2><%= section.title %></h2>
                    <% } %>

                    <% if (section.type === 'text') { %>
                        <% section.paragraphs.forEach((paragraph) => { 
                            const rendered = renderParagraph(paragraph, section.highlights, section.highlightsStrong);
                        %>
                            <p class="<%= rendered.className %>"><%- rendered.html %></p>
                        <% }) %>
                    <% } %>

                    <% if (section.type === 'code') { %>
                        <pre><code><%= section.code %></code></pre>
                    <% } %>

                    <% if (section.type === 'commands') { %>
                        <pre><code><%= section.command %></code></pre>
                    <% } %>

                    <% if (section.type === 'list') { %>
                        <% if (section.description) { %>
                            <p><%= section.description %></p>
                        <% } %>
                        <ul>
                            <% section.items.forEach((item) => { 
                                if (Array.isArray(item)) {
                            %>
                                <li><%- renderParts(item) %></li>
                            <% } else if (item && typeof item === "object") { %>
                                <% if (Array.isArray(item.parts)) { %>
                                    <li><%- renderParts(item.parts) %></li>
                                <% } else { %>
                                    <li><%= item.text || "" %></li>
                                <% } %>
                            <% } else { %>
                                <li><%= item %></li>
                            <% } %>
                            <% }) %>
                        </ul>
                    <% } %>

                    <% if (section.type === 'closing') { %>
                        <% section.paragraphs.forEach((paragraph) => { %>
                            <p><%= paragraph %></p>
                        <% }) %>
                    <% } %>
                </section>
                <% } %>
            <% }) %>
        </article>
    </main>

    <script src="/script.js"></script>
</body>

</html>
