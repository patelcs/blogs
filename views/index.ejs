<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="styles.css">
    <title>Blogs</title>
</head>

<body>
    <%- include("components/Navbar") %>

    <main class="page">
        <header class="hero">
            <p class="eyebrow">Learning Log</p>
            <h1>Blog Posts</h1>
            <p class="subtitle">Short, practical notes from my journey learning Rust and building projects.</p>
        </header>

        <section class="list">
            <h2>Latest Posts</h2>
            <div class="cards">
                <% blogs.forEach((blog) => { %>
                    <article class="card">
                        <div class="card-meta">
                            <span><%= blog.series %></span>
                            <span><%= blog.date %></span>
                        </div>
                        <h3><a href="/blogs/<%= blog.slug %>"><%= blog.title %></a></h3>
                        <p><%= blog.excerpt %></p>
                        <a class="card-link" href="/blogs/<%= blog.slug %>">Read post</a>
                    </article>
                <% }) %>
            </div>
        </section>
    </main>

    <script src="script.js"></script>
</body>

</html>
